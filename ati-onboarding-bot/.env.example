# =============================================================================
# ATI Client Onboarding Agent — Environment Variables
# Copy to .env and fill in values. See SETUP.md for full setup guide.
# =============================================================================

# --- LLM (Ollama) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llava
OLLAMA_CHAT_TEMPERATURE=0.3

# --- MongoDB (required) ---
# Atlas: Connect → Drivers → paste connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ati_onboarding

# --- Auth (required) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=generate-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Google OAuth (optional) ---
# See SETUP.md Section 5
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8001/api/auth/google/callback
FRONTEND_URL=http://127.0.0.1:8001

# --- First admin user (seeded on startup) ---
ADMIN_EMAIL=admin@awesometechinc.com
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_FULL_NAME=ATI Admin

# --- Storage ---
STORAGE_ROOT=./client_data
ATI_KB_ROOT=./ati_kb

# --- Encryption (required for SMTP password storage in MongoDB) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-with-fernet-command-in-setup-md

# --- ATI branding defaults (overridable in admin System Configuration) ---
ATI_PRIVACY_URL=/privacy.html
ATI_SUPPORT_EMAIL=support@awesometechinc.com
ATI_PHONE=877-284-4968

LOG_LEVEL=INFO

# NOTE: SMTP credentials are NOT stored in .env — configure via admin UI:
# http://127.0.0.1:8001/admin/config-smtp.html (see SETUP.md Section 6)
